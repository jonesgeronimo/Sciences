body {
  font-family: 'Segoe UI', sans-serif;
  min-height: 100vh;
  background: linear-gradient(135deg, #e0f2fe 0%, #f0fdf4 100%);
  padding: 24px 16px;
  color: #1e293b;
}

.container { max-width: 900px; margin: 0 auto; }

h1 {
  text-align: center;
  font-size: 26px;
  font-weight: 700;
  margin-bottom: 8px;
}

.subtitle {
  text-align: center;
  color: #475569;
  font-size: 15px;
  margin-bottom: 24px;
}

/* Card pool */
#pool-box {
  background: white;
  border-radius: 16px;
  padding: 16px 20px;
  margin-bottom: 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.07);
}

.pool-label {
  font-weight: 600;
  color: #64748b;
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
}

#pool {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  min-height: 40px;
}

/* Drop zones */
.zones {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 24px;
}

.zone {
  background: white;
  border-radius: 16px;
  border: 2px dashed #cbd5e1;
  min-height: 220px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  transition: border-color 0.2s, background 0.2s;
}

.zone.drag-over-uni  { border-color: #3b82f6; background: #eff6ff; }
.zone.drag-over-pluri { border-color: #22c55e; background: #f0fdf4; }

.zone-title {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 12px;
}

.zone-icon {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px;
}

.zone-icon.uni   { background: #dbeafe; }
.zone-icon.pluri { background: #dcfce7; }

.zone-name {
  font-size: 16px;
  font-weight: 700;
  text-transform: capitalize;
}

.zone-name.uni   { color: #1d4ed8; }
.zone-name.pluri { color: #15803d; }

.zone-cards {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  min-height: 40px;
}

.zone-empty {
  color: #94a3b8;
  font-size: 13px;
  font-style: italic;
}

/* Cards */
.card {
  border-radius: 12px;
  overflow: hidden;
  border: 2px solid #e2e8f0;
  background: #f8fafc;
  width: 110px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  cursor: grab;
  transition: transform 0.15s, box-shadow 0.15s;
  user-select: none;
}

.card:hover { transform: scale(1.05); box-shadow: 0 4px 16px rgba(0,0,0,0.13); }
.card.dragging { opacity: 0.4; }

.card img {
  width: 100%;
  height: 80px;
  object-fit: cover;
  display: block;
  pointer-events: none;
}

.card-name {
  padding: 6px 8px;
  font-size: 12px;
  font-weight: 600;
  text-align: center;
}

/* In a drop zone, cards are slightly smaller */
.zone-cards .card { width: 100px; }
.zone-cards .card img { height: 72px; }

/* Result states */
.card.correct { outline: 3px solid #22c55e; background: #f0fdf4; }
.card.wrong   { outline: 3px solid #ef4444; background: #fef2f2; }

/* Actions */
.actions { text-align: center; display: flex; gap: 12px; justify-content: center; }

button {
  border: none;
  border-radius: 10px;
  padding: 12px 32px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}

#btn-check {
  background: #0f172a;
  color: white;
}

#btn-check:disabled {
  background: #cbd5e1;
  cursor: not-allowed;
}

#btn-reset {
  background: #0f172a;
  color: white;
  display: none;
}

#score-box {
  border-radius: 12px;
  padding: 12px 24px;
  font-size: 16px;
  font-weight: 700;
  display: none;
}

#score-box.perfect { background: #f0fdf4; border: 2px solid #22c55e; color: #15803d; }
#score-box.partial { background: #fef9c3; border: 2px solid #facc15; color: #854d0e; }

#hint-box {
  display: none;
  margin-top: 20px;
  background: white;
  border-radius: 12px;
  padding: 14px 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  font-size: 14px;
  color: #475569;
  line-height: 1.6;
}

@media (max-width: 600px) {
  .zones { grid-template-columns: 1fr; }
  .card { width: 90px; }
  .card img { height: 65px; }
}
