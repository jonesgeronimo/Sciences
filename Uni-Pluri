<body>
<div class="container">
  <h1>🔬 Unicellulaire ou Pluricellulaire ?</h1>
  <p class="subtitle">Glisse chaque organisme dans la bonne colonne.</p>

  <div id="pool-box">
    <div class="pool-label">Organismes à classer</div>
    <div id="pool"></div>
  </div>

  <div class="zones">
    <div class="zone" id="zone-unicellulaire" data-cat="unicellulaire">
      <div class="zone-title">
        <div class="zone-icon uni">1️⃣</div>
        <span class="zone-name uni">Unicellulaire</span>
      </div>
      <div class="zone-cards" id="cards-unicellulaire">
        <span class="zone-empty">Dépose ici…</span>
      </div>
    </div>
    <div class="zone" id="zone-pluricellulaire" data-cat="pluricellulaire">
      <div class="zone-title">
        <div class="zone-icon pluri">🧬</div>
        <span class="zone-name pluri">Pluricellulaire</span>
      </div>
      <div class="zone-cards" id="cards-pluricellulaire">
        <span class="zone-empty">Dépose ici…</span>
      </div>
    </div>
  </div>

  <div class="actions">
    <button id="btn-check" disabled>Place tous les organismes d'abord…</button>
    <div id="score-box"></div>
    <button id="btn-reset">🔄 Recommencer</button>
  </div>

  <div id="hint-box">
    💡 <strong>Rappel :</strong> Les organismes <em>unicellulaires</em> sont composés d'<strong>une seule cellule</strong> qui fait tout elle-même. Les organismes <em>pluricellulaires</em> ont <strong>plusieurs cellules spécialisées</strong>, chacune adaptée à une fonction précise.
  </div>
</div>

<script>
  const organisms = [
    { id: "frontonia",  name: "Frontonia",        category: "unicellulaire",   img: "https://upload.wikimedia.org/wikipedia/commons/thumb/9/9d/Frontonia_leucas.jpg/320px-Frontonia_leucas.jpg" },
    { id: "amibe",      name: "Amibe",             category: "unicellulaire",   img: "https://upload.wikimedia.org/wikipedia/commons/thumb/6/sixty/Amoeba_proteus_with_many_pseudopodia.jpg/320px-Amoeba_proteus_with_many_pseudopodia.jpg" },
    { id: "tardigrade", name: "Tardigrade",        category: "pluricellulaire", img: "https://upload.wikimedia.org/wikipedia/commons/thumb/9/9f/Hypsibius_dujardini.jpg/320px-Hypsibius_dujardini.jpg" },
    { id: "ecoli",      name: "Escherichia coli",  category: "unicellulaire",   img: "https://upload.wikimedia.org/wikipedia/commons/thumb/3/32/EscherichiaColi_NIAID.jpg/320px-EscherichiaColi_NIAID.jpg" },
    { id: "levure",     name: "Levure",            category: "unicellulaire",   img: "https://upload.wikimedia.org/wikipedia/commons/thumb/4/4b/Yeast_-_S._cerevisiae_SEM.jpg/320px-Yeast_-_S._cerevisiae_SEM.jpg" },
    { id: "rotifere",   name: "Rotifère",          category: "pluricellulaire", img: "https://upload.wikimedia.org/wikipedia/commons/thumb/d/db/Bdelloid_Rotifer.jpg/320px-Bdelloid_Rotifer.jpg" },
  ];

  // Shuffle
  const shuffled = organisms.sort(() => Math.random() - 0.5);

  let placements = {}; // id -> category
  let submitted = false;
  let draggedId = null;

  function buildCard(org, inPool) {
    const card = document.createElement("div");
    card.className = "card";
    card.id = "card-" + org.id;
    card.draggable = true;

    const img = document.createElement("img");
    img.src = org.img;
    img.alt = org.name;
    img.onerror = () => { img.src = `https://placehold.co/110x80/e2e8f0/94a3b8?text=${encodeURIComponent(org.name)}`; };

    const label = document.createElement("div");
    label.className = "card-name";
    label.textContent = org.name;

    card.appendChild(img);
    card.appendChild(label);

    card.addEventListener("dragstart", () => {
      if (submitted) return;
      draggedId = org.id;
      setTimeout(() => card.classList.add("dragging"), 0);
    });

    card.addEventListener("dragend", () => {
      card.classList.remove("dragging");
    });

    // Click to return to pool (when in a zone)
    if (!inPool) {
      card.addEventListener("click", () => {
        if (submitted) return;
        delete placements[org.id];
        document.getElementById("pool").appendChild(card);
        updateEmptyHints();
        updateButton();
      });
    }

    return card;
  }

  function updateEmptyHints() {
    ["unicellulaire", "pluricellulaire"].forEach(cat => {
      const container = document.getElementById("cards-" + cat);
      const hasCards = container.querySelector(".card");
      let hint = container.querySelector(".zone-empty");
      if (!hasCards) {
        if (!hint) {
          hint = document.createElement("span");
          hint.className = "zone-empty";
          hint.textContent = "Dépose ici…";
          container.appendChild(hint);
        }
      } else {
        if (hint) hint.remove();
      }
    });
  }

  function updateButton() {
    const remaining = shuffled.filter(o => !placements[o.id]).length;
    const btn = document.getElementById("btn-check");
    if (remaining === 0) {
      btn.disabled = false;
      btn.textContent = "Vérifier mes réponses";
    } else {
      btn.disabled = true;
      btn.textContent = `Place encore ${remaining} organisme(s)…`;
    }
  }

  function setupZone(zoneEl) {
    zoneEl.addEventListener("dragover", e => {
      e.preventDefault();
      const cat = zoneEl.dataset.cat;
      zoneEl.classList.add(cat === "unicellulaire" ? "drag-over-uni" : "drag-over-pluri");
    });

    zoneEl.addEventListener("dragleave", () => {
      zoneEl.classList.remove("drag-over-uni", "drag-over-pluri");
    });

    zoneEl.addEventListener("drop", e => {
      e.preventDefault();
      zoneEl.classList.remove("drag-over-uni", "drag-over-pluri");
      if (!draggedId || submitted) return;

      const cat = zoneEl.dataset.cat;
      placements[draggedId] = cat;

      const org = shuffled.find(o => o.id === draggedId);
      const card = document.getElementById("card-" + draggedId);

      // Move card to this zone
      const container = document.getElementById("cards-" + cat);
      container.appendChild(card);

      updateEmptyHints();
      updateButton();
      draggedId = null;
    });
  }

  // Also allow dropping back to pool
  const pool = document.getElementById("pool");
  pool.addEventListener("dragover", e => e.preventDefault());
  pool.addEventListener("drop", e => {
    e.preventDefault();
    if (!draggedId || submitted) return;
    delete placements[draggedId];
    const card = document.getElementById("card-" + draggedId);
    pool.appendChild(card);
    updateEmptyHints();
    updateButton();
    draggedId = null;
  });

  document.getElementById("btn-check").addEventListener("click", () => {
    submitted = true;
    let score = 0;

    shuffled.forEach(org => {
      const card = document.getElementById("card-" + org.id);
      card.draggable = false;
      card.style.cursor = "default";
      if (placements[org.id] === org.category) {
        card.classList.add("correct");
        const label = card.querySelector(".card-name");
        label.textContent = org.name + " ✅";
        score++;
      } else {
        card.classList.add("wrong");
        const label = card.querySelector(".card-name");
        label.textContent = org.name + " ❌";
      }
    });

    const scoreBox = document.getElementById("score-box");
    scoreBox.style.display = "block";
    if (score === shuffled.length) {
      scoreBox.className = "perfect";
      scoreBox.textContent = `🎉 Parfait ! ${score}/${shuffled.length} — Bravo !`;
    } else {
      scoreBox.className = "partial";
      scoreBox.textContent = `${score}/${shuffled.length} — Essaie encore !`;
      document.getElementById("hint-box").style.display = "block";
    }

    document.getElementById("btn-check").style.display = "none";
    document.getElementById("btn-reset").style.display = "inline-block";
  });

  document.getElementById("btn-reset").addEventListener("click", () => {
    placements = {};
    submitted = false;

    // Clear zones
    ["unicellulaire", "pluricellulaire"].forEach(cat => {
      document.getElementById("cards-" + cat).innerHTML = '<span class="zone-empty">Dépose ici…</span>';
    });

    // Rebuild pool
    pool.innerHTML = "";
    shuffled.sort(() => Math.random() - 0.5).forEach(org => {
      pool.appendChild(buildCard(org, true));
    });

    document.getElementById("score-box").style.display = "none";
    document.getElementById("hint-box").style.display = "none";
    document.getElementById("btn-reset").style.display = "none";
    document.getElementById("btn-check").style.display = "inline-block";
    updateButton();
  });

  // Init
  setupZone(document.getElementById("zone-unicellulaire"));
  setupZone(document.getElementById("zone-pluricellulaire"));

  shuffled.forEach(org => {
    pool.appendChild(buildCard(org, true));
  });

  updateButton();
</script>

</body>
</html>
